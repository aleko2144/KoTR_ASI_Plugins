{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows-msvc",
      "displayName": "Windows / Visual Studio (MSVC, 32-bit)",
      "generator": "Visual Studio 17 2022",
      "architecture": "Win32",
      "binaryDir": "${sourceDir}/build/msvc"
    },
    {
      "name": "windows-ninja",
      "displayName": "Windows / Ninja (run from an x86 Native Tools prompt)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ninja",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "linux-mingw",
      "displayName": "Linux -> Windows cross-compile (MinGW-w64)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/mingw",
      "toolchainFile": "${sourceDir}/toolchain-mingw.cmake",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }
  ],
  "buildPresets": [
    { "name": "windows-msvc",  "configurePreset": "windows-msvc", "configuration": "Release" },
    { "name": "windows-ninja", "configurePreset": "windows-ninja" },
    { "name": "linux-mingw",   "configurePreset": "linux-mingw" }
  ]
}
